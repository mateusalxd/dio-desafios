{
  "name": "nodejs-container",
  "version": "1.0.0",
  "description": "API mínima com Fastfy e Node.js",
  "scripts": {
    "dist": "tsdown src/server.ts --format cjs --dst",
    "start:dev": "tsx src/server.ts",
    "start:watch": "tsx watch src/server.ts",
    "start:dist": "npm run dist && node dist/server.cjs"
  },
  "keywords": [],
  "author": "Mateus Alexandre",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "fastify": "^5.8.5"
  }
}
